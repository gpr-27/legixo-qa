# Copy to .env and fill in your own keys. Never commit the real .env.

# Groq — answer LLM (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here

# Google Gemini AI Studio — embeddings (https://aistudio.google.com/apikey)
# The free AI Studio key, NOT a paid Vertex AI key. GOOGLE_API_KEY also works.
GEMINI_API_KEY=your_gemini_key_here

# Pinecone — vector index (https://app.pinecone.io)
PINECONE_API_KEY=pcsk_your_pinecone_key_here

# --- Optional overrides (defaults shown) ---
# PINECONE_INDEX_NAME=legixo-qa
# PINECONE_NAMESPACE=legal-docs
# ANSWER_MODEL=llama-3.3-70b-versatile
# EMBED_MODEL=gemini-embedding-001
# EMBED_DIM=768
# TOP_K=4
# SCORE_THRESHOLD=0.55
# QUERY_FANOUT=3
# MAX_LOOPS=2
